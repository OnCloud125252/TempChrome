{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "target": "ES2020",
    "module": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "scripts/sync-options-schema.ts",
    "src/**/*",
    "raycast-env.d.ts"
  ]
}