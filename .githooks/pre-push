#!/usr/bin/env bash

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TempChrome — Pre-Push Hook
# Runs gitleaks on the push range, shellcheck on all shell scripts,
# and ray lint + ray build on the raycast extension.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TOTAL_STEPS=5

# ── Read push refs from stdin ────────────────────────────────────
# Git sends one line per ref: <local_ref> <local_sha> <remote_ref> <remote_sha>
declare -a _PUSH_LOCAL_SHAS=()
declare -a _PUSH_REMOTE_SHAS=()

while IFS=' ' read -r -t 1 _local_ref _local_sha _remote_ref _remote_sha; do
  [[ -z "$_local_ref" ]] && continue
  _PUSH_LOCAL_SHAS+=("$_local_sha")
  _PUSH_REMOTE_SHAS+=("$_remote_sha")
done

# Detect remote default branch; fall back to "main"
DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
DEFAULT_BRANCH="${DEFAULT_BRANCH:-main}"

# Colors
_CLI_RED='\033[0;31m'
_CLI_GREEN='\033[0;32m'
_CLI_YELLOW='\033[0;33m'
_CLI_PURPLE='\033[0;35m'
_CLI_CYAN='\033[0;36m'
_CLI_GRAY='\033[0;90m'
_CLI_NC='\033[0m'

_CLI_WIDTH="${COLUMNS:-$( (tput cols </dev/tty) 2>/dev/null || tput cols 2>/dev/null || echo 80)}"

_CLI_CHECK="${_CLI_GREEN}[✓]${_CLI_NC}"
_CLI_CROSS="${_CLI_RED}[✗]${_CLI_NC}"
_CLI_WARN="${_CLI_YELLOW}[!]${_CLI_NC}"
_CLI_INFO="${_CLI_CYAN}[i]${_CLI_NC}"

log_info()    { echo -e "$_CLI_INFO $1"; }
log_success() { echo -e "$_CLI_CHECK $1"; }
log_warn()    { echo -e "$_CLI_WARN $1"; }
log_error()   { echo -e "$_CLI_CROSS $1"; }

print_divider() {
  local color="${1:-$_CLI_PURPLE}" label="${2:-}"
  local width="$_CLI_WIDTH"
  if [[ -n "$label" ]]; then
    local padding=$((width - ${#label} - 6))
    local fill
    printf -v fill '%*s' "$padding" ''
    printf '%b━━━━[%s]%s%b\n' "$color" "$label" "${fill// /━}" "$_CLI_NC"
  else
    local fill
    printf -v fill '%*s' "$width" ''
    printf '%b%s%b\n' "$color" "${fill// /━}" "$_CLI_NC"
  fi
}

run_step() {
  local step_num="$1"
  local step_name="$2"
  local step_cmd="$3"
  local tmp_out
  tmp_out=$(mktemp)

  # shellcheck disable=SC2059 # colors are our own constants, not user input
  printf "${_CLI_GRAY}[·]${_CLI_NC} ${_CLI_GRAY}[${step_num}/${TOTAL_STEPS}]${_CLI_NC} ${step_name}..."

  if eval "$step_cmd" >"$tmp_out" 2>&1; then
    # shellcheck disable=SC2059
    printf "\r${_CLI_CHECK} ${_CLI_GRAY}[${step_num}/${TOTAL_STEPS}]${_CLI_NC} ${step_name}\n"
    rm -f "$tmp_out"
    return 0
  else
    printf "\n\n"
    cat "$tmp_out"
    rm -f "$tmp_out"
    echo ""
    log_error "${_CLI_GRAY}[${step_num}/${TOTAL_STEPS}]${_CLI_NC} ${step_name} ${_CLI_RED}failed${_CLI_NC}"
    echo ""
    log_info "Fix the errors above, then try pushing again."
    echo ""
    print_divider "$_CLI_RED"
    echo ""
    return 1
  fi
}

# ── Push Range Helper ────────────────────────────────────────────
# get_push_range <local_sha> <remote_sha>
# Prints the commit range being pushed for a single ref.
# Prints nothing for branch deletions (all-zeros SHA).
get_push_range() {
  local local_sha="$1" remote_sha="$2"

  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && return

  if [[ -n "$remote_sha" && "$remote_sha" != "0000000000000000000000000000000000000000" ]]; then
    echo "${remote_sha}..${local_sha}"
  else
    local base
    base=$(git merge-base "$local_sha" "origin/${DEFAULT_BRANCH}" 2>/dev/null || true)
    echo "${base:-HEAD~20}..${local_sha}"
  fi
}

# ── Check Functions ──────────────────────────────────────────────

check_gitleaks() {
  for i in "${!_PUSH_LOCAL_SHAS[@]}"; do
    local range
    range=$(get_push_range "${_PUSH_LOCAL_SHAS[$i]}" "${_PUSH_REMOTE_SHAS[$i]}")
    [[ -z "$range" ]] && continue

    echo "Scanning range: ${range}"
    gitleaks detect --log-opts="$range" --no-banner --verbose || return 1
  done
}

check_shellcheck_all() {
  if ! command -v shellcheck &>/dev/null; then
    echo "shellcheck not installed — install with: brew install shellcheck"
    return 1
  fi

  mapfile -t sh_files < <(git ls-files '*.sh')
  if [[ ${#sh_files[@]} -eq 0 ]]; then
    echo "No .sh files tracked — skipping"
    return 0
  fi

  shellcheck "${sh_files[@]}"
}

check_raycast_lint() {
  (cd raycast && bun run lint)
}

check_raycast_build() {
  (cd raycast && bun run build)
}

check_raycast_schema_sync() {
  # `prelint` + `prebuild` already ran `bun run sync:options`, so the
  # working tree's raycast/package.json reflects the latest schema. If
  # it differs from HEAD, the committed launch.preferences block is
  # stale — block the push so drift can't reach the remote.
  if ! git diff --quiet HEAD -- raycast/package.json; then
    echo "raycast/package.json on HEAD is out of sync with src/options/schema.ts"
    echo ""
    echo "Amend (or add a follow-up commit) with the regenerated"
    echo "package.json, then re-push. The fresh file is already in your"
    echo "working tree — stage it with:"
    echo ""
    echo "    git add raycast/package.json"
    return 1
  fi
}

# ── Main ─────────────────────────────────────────────────────────

echo ""
print_divider "$_CLI_PURPLE" "Pre-Push Checks"
echo ""

# 1. Secret detection with gitleaks (push range)
if command -v gitleaks &>/dev/null; then
  run_step 1 "gitleaks (secret scan)" "check_gitleaks" || exit 1
else
  log_warn "${_CLI_GRAY}[1/${TOTAL_STEPS}]${_CLI_NC} gitleaks not installed — skipping"
  log_info "Install with: ${_CLI_CYAN}brew install gitleaks${_CLI_NC}"
  echo ""
fi

# 2. shellcheck on all tracked .sh files
run_step 2 "shellcheck (all .sh)"      "check_shellcheck_all"  || exit 1

# 3. ray lint (verify, no fix)
run_step 3 "ray lint"                  "check_raycast_lint"    || exit 1

# 4. ray build (also typechecks the raycast extension)
run_step 4 "ray build"                 "check_raycast_build"   || exit 1

# 5. raycast/package.json in sync with src/options/schema.ts on HEAD
run_step 5 "raycast schema sync check" "check_raycast_schema_sync" || exit 1

echo ""
log_success "All pre-push checks passed"
echo ""
print_divider "$_CLI_PURPLE"
echo ""
